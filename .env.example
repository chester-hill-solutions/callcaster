SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=local-anon-key
SUPABASE_SERVICE_KEY=local-service-role-key
SUPABASE_PUBLISHABLE_KEY=local-publishable-key

# Set this to your current ngrok HTTPS URL when testing Twilio callbacks locally.
BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# Real Twilio credentials are required for calling, SMS, and webhook validation.
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15555550100

# Placeholder values are enough to satisfy startup validation until you use these integrations.
STRIPE_SECRET_KEY=sk_test_placeholder
RESEND_API_KEY=re_placeholder

# Optional. Only needed for AI-backed features.
OPENAI_API_KEY=
