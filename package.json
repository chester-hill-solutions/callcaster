{
  "name": "callcaster",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "node ./scripts/local/dev-stable.mjs",
    "dev:calling:sync": "node ./scripts/local/sync-calling-dev.mjs",
    "tools:sync-inbound-sms": "node ./scripts/one-off/sync-inbound-sms-from-twilio.mjs",
    "tools:routes:baseline": "node scripts/verify-route-tree.mjs --update-baseline",
    "tools:routes:verify": "node scripts/verify-route-tree.mjs",
    "tools:check-file-size": "node scripts/check-app-file-size.mjs",
    "tools:routes:flat-id-to-path": "node scripts/lib/route-flat-id-to-path.mjs --print",
    "tools:routes:folderize": "node scripts/folderize-routes.mjs",
    "tools:routes:consolidate": "node scripts/consolidate-route-modules.mjs",
    "tools:routes:rename": "node scripts/rename-route-modules.mjs",
    "tools:routes:imports": "node scripts/rewrite-route-imports.mjs && node scripts/normalize-route-test-imports.mjs",
    "tools:routes:repair": "node scripts/repair-consolidated-routes.mjs && node scripts/fix-route-lib-imports.mjs && node scripts/repair-route-exports.mjs && node scripts/fix-route-remix-imports.mjs && node scripts/fix-route-tests-rr7.mjs && node scripts/fix-route-test-module-paths.mjs",
    "tools:routes:dynamic-imports": "node scripts/route-dynamic-server-imports.mjs && node scripts/fix-route-module-scope-server-refs.mjs",
    "tools:routes:legacy-delete": "node scripts/delete-legacy-routes.mjs",
    "tools:routes:sync-config": "node scripts/sync-config-after-route-cleanup.mjs",
    "tools:components:move-settings": "node scripts/move-component-settings.mjs",
    "tools:prune:hygiene": "node scripts/prune-repo-hygiene.mjs",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "node ./server/index.js",
    "typecheck": "react-router typegen && tsc",
    "typecheck:deno": "node scripts/check-deno-functions.mjs",
    "test": "npm run test:node && npm run test:ui",
    "test:node": "vitest run -c vitest.node.config.ts",
    "test:ui": "vitest run -c vitest.ui.config.ts",
    "test:coverage:vitest": "npm run test:coverage:node && npm run test:coverage:ui",
    "test:coverage:node": "vitest run -c vitest.node.config.ts --coverage",
    "test:coverage:ui": "vitest run -c vitest.ui.config.ts --coverage",
    "test:coverage:deno": "npx deno test --no-check --allow-env --allow-read --allow-net --coverage=coverage/deno supabase/functions/__tests__ && npx deno coverage --lcov --output=coverage/deno/lcov.info coverage/deno",
    "test:coverage:merge": "node scripts/coverage/merge-and-check.mjs",
    "test:coverage:merge:strict": "COVERAGE_FULL=1 node scripts/coverage/merge-and-check.mjs",
    "test:coverage:report:strict": "node scripts/coverage/report-strict-failures.mjs",
    "test:coverage": "npm run test:coverage:vitest && npm run test:coverage:deno && npm run test:coverage:merge",
    "check:client-bundle": "node scripts/check-client-bundle-for-server-imports.mjs",
    "check:route-server-leaks": "node scripts/check-route-server-leaks.mjs"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.15",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@react-router/express": "^7.0.0",
    "@react-router/node": "^7.0.0",
    "@stripe/stripe-js": "^4.1.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.86.2",
    "@tanstack/react-table": "^8.17.3",
    "@twilio/voice-sdk": "^2.10.2",
    "buffer-polyfill": "npm:buffer@^6.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^5.5.6",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "isbot": "^4.1.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.378.0",
    "morgan": "^1.10.0",
    "next-themes": "^0.3.0",
    "openai": "^6.38.0",
    "react": "^18.2.0",
    "react-csv": "^2.2.2",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.2.0",
    "react-icons": "^5.2.1",
    "react-router": "^7.0.0",
    "remix-utils": "^7.6.0",
    "resend": "^6.0.2",
    "sonner": "^1.4.41",
    "stripe": "^16.6.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^5.0.4",
    "wavefile": "^11.0.0",
    "ws": "^8.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-router/dev": "^7.0.0",
    "@react-router/fs-routes": "^7.0.0",
    "@react-router/remix-routes-option-adapter": "^7.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@types/twilio": "^3.19.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.19",
    "deno": "^2.6.8",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^26.1.0",
    "json5": "^2.2.3",
    "lcov-result-merger": "^5.0.1",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "remix-flat-routes": "^0.8.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.2.15"
  },
  "overrides": {
    "zod": "^4.4.3"
  }
}
